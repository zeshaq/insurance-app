{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist/server",
    "rootDir": "server"
  },
  "include": [
    "server"
  ],
  "exclude": [
    "**/*.test.ts"
  ]
}
