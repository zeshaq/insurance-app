<?xml version="1.0" encoding="UTF-8"?>
<server description="insurance-app">

    <featureManager>
        <feature>webProfile-10.0</feature>
        <feature>microProfile-6.1</feature>
        <feature>jdbc-4.3</feature>
        <feature>mpReactiveMessaging-3.0</feature>
    </featureManager>

    <variable name="http.port" defaultValue="9080"/>
    <variable name="https.port" defaultValue="9443"/>

    <httpEndpoint id="defaultHttpEndpoint"
                  host="*"
                  httpPort="${http.port}"
                  httpsPort="${https.port}"/>

    <webApplication contextRoot="/"
                    location="insurance-app.war">
        <application-bnd>
            <security-role name="APPLICATION">
                <special-subject type="ALL_AUTHENTICATED_USERS"/>
            </security-role>
        </application-bnd>
    </webApplication>

    <!-- Postgres driver lives in /config/postgresql/, copied in by the Containerfile.
         shared.resource.dir resolves to /config/ for the Liberty container image. -->
    <library id="postgresql-driver">
        <fileset dir="/config/postgresql" includes="*.jar"/>
    </library>

    <dataSource id="insuranceDS"
                jndiName="jdbc/insuranceDS"
                transactional="true">
        <jdbcDriver libraryRef="postgresql-driver"/>
        <properties.postgresql serverName="postgres"
                               portNumber="5432"
                               databaseName="insurance"
                               user="insurance"
                               password="insurance"/>
    </dataSource>

    <!-- mpJwt: validate JWTs minted by WSO2 IS.
         - issuer must match the `iss` claim WSO2 IS puts in the token. By
           default that's "https://localhost:9443/oauth2/token" because we
           haven't customized the IS hostname in its deployment.toml.
         - jwksUri points at the publicly-reachable LE-fronted IS endpoint
           so Liberty's JWKS fetch uses a trusted cert without a custom
           truststore.
         - audiences is intentionally omitted — WSO2 IS sets `aud` to the
           dynamic client_id of the requesting app, which would force us to
           hardcode a generated ID into server.xml. With it omitted, Liberty
           skips audience validation. Token authenticity is still enforced
           via signature + issuer. -->
    <mpJwt id="defaultMpJwt"
           jwksUri="http://wso2is:9763/oauth2/jwks"
           issuer="https://is.insurance-app.comptech-lab.com/oauth2/token"
           userNameAttribute="sub"
           groupNameAttribute="aut"
           ignoreApplicationAuthMethod="false"
           mapToUserRegistry="false"/>

    <!-- Liberty's appSecurity-5.0 logs CWWKS3005E ("No UserRegistry") even
         when mpJwt is the only auth mechanism we use. Mounting an empty
         basicRegistry satisfies the probe without enabling Basic auth — no
         users defined, so there's nothing to log in with that way. -->
    <ltpa keysPassword="ltpaP@ssw0rd"/>

    <basicRegistry id="basic" realm="insurance-app">
        <user name="Y7AjfZt6HZkvMI1PvJPbX4Pzkw8a" password="unused"/>
    </basicRegistry>

    <webAppSecurity allowFailOverToBasicAuth="false"/>

    <!-- mTLS to partner-mock (slice 10). mpRestClient-3.0 in Liberty
         24.0.0.12 ignores per-client trustStore/keyStore properties for
         outbound HTTPS — it always uses defaultSSLConfig. So we override
         defaultKeyStore + add a defaultTrustStore: the JVM default SSL
         context already has the partner CA + client cert mounted in by
         `podman run -v compose/certs:/config/partner-certs:ro`.
         Side-effect: the Liberty HTTPS endpoint on 9443 will present the
         insurance-mi-client cert as its server cert. Harmless for the
         smoke (everything uses HTTP 9080) but worth noting before a
         production deploy. -->
    <keyStore id="defaultKeyStore"
              location="/config/partner-certs/mi-keystore.jks"
              type="JKS"
              password="wso2carbon"/>
    <keyStore id="defaultTrustStore"
              location="/config/partner-certs/mi-truststore.jks"
              type="JKS"
              password="wso2carbon"/>
    <ssl id="defaultSSLConfig"
         keyStoreRef="defaultKeyStore"
         trustStoreRef="defaultTrustStore"/>

    <logging consoleLogLevel="INFO"/>
</server>
